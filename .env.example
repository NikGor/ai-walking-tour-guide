# ── LLM ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Google ─────────────────────────────────────────────────────────────────────
# Google Places API (nearby venue search)
GOOGLE_API_KEY=your_google_api_key_here

# Gemini API (web search grounding)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Database (optional) ────────────────────────────────────────────────────────
# Default: sqlite+aiosqlite:///./data/solaris.db
# SOLARIS_DB_URL=sqlite+aiosqlite:///./data/solaris.db
